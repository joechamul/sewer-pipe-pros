---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCall from '../components/StickyCall.astro';
import ContactSection from '../components/ContactSection.astro';
import EmergencyBanner from '../components/EmergencyBanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Contact Sewer Pipe Pros · Call (310) 780-0362"
  description="Contact Sewer Pipe Pros Inc. for licensed plumbing, drain, and sewer service across Greater Los Angeles. Call 24/7 at (310) 780-0362 or request service online."
>
  <Header />

  <main id="main">
    <section class="contact-hero">
      <div class="container">
        <nav class="contact-hero__crumbs" aria-label="Breadcrumb">
          <a href={`${base}/`}>Home</a>
          <span aria-hidden="true">/</span>
          <span>Contact</span>
        </nav>
        <span class="chip chip--dark">We answer 24/7 · No call trees</span>
        <h1>Get in touch.</h1>
        <p>Call, text, or send a service request. We respond fast — and for emergencies, a real human picks up the phone.</p>
      </div>
    </section>

    <ContactSection
      eyebrow="Contact"
      title="Tell us what's going on."
      lead="Share a few details and we'll call back with honest, upfront pricing. Or dial (310) 780-0362 and talk to us now."
    />

    <EmergencyBanner />
  </main>

  <Footer />
  <StickyCall />
</BaseLayout>

<style>
  .contact-hero {
    background:
      radial-gradient(ellipse at 10% 100%, rgba(229,32,42,0.18), transparent 55%),
      radial-gradient(ellipse at 100% 0%, rgba(63,194,238,0.18), transparent 55%),
      var(--ink);
    color: #fff;
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .contact-hero__crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
  }
  .contact-hero__crumbs a { color: var(--cyan); }
  .contact-hero h1 { color: #fff; margin: 1rem 0 0.8rem; }
  .contact-hero p { color: #c9ccd6; max-width: 60ch; font-size: 1.15rem; }
</style>
