---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopStrip from '../../components/TopStrip.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import StickyCall from '../../components/StickyCall.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import ContactSection from '../../components/ContactSection.astro';
import Icon from '../../components/Icon.astro';
import { areas } from '../../data/areas';

export function getStaticPaths() {
  return areas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const defaultBlurb = `Licensed plumbing, drain, and sewer service in ${area.name}, California. Homes, apartments, and commercial properties — we handle everything from slow drains to trenchless sewer replacement.`;
const blurb = area.blurb ?? defaultBlurb;

const description = `Plumbing in ${area.name}, CA. Licensed LA contractor (#1126184) handling drain cleaning, trenchless sewer, water heaters, repipes & more. Call (310) 780-0362.`;
---

<BaseLayout
  title={`Plumbing in ${area.name} · Sewer Pipe Pros`}
  description={description}
>
  <TopStrip />
  <Header />

  <main id="main">
    <!-- Area hero -->
    <section class="area-hero">
      <div class="container area-hero__inner">
        <nav class="area-hero__crumbs" aria-label="Breadcrumb">
          <a href={`${base}/`}>Home</a>
          <span aria-hidden="true">/</span>
          <a href={`${base}/areas/`}>Service Areas</a>
          <span aria-hidden="true">/</span>
          <span>{area.name}</span>
        </nav>

        <span class="chip chip--dark">
          <Icon name="map-pin" size={14} /> Serving {area.name}, CA
        </span>

        <h1 class="area-hero__title">Plumbing in {area.name}</h1>
        <p class="area-hero__lead">{blurb}</p>

        <div class="area-hero__ctas">
          <a class="btn btn--lg" href="tel:+13107800362">
            <Icon name="phone" size={20} /> Call (310) 780-0362
          </a>
          <a class="btn btn--ghost btn--lg" href="#contact">Request Service</a>
        </div>

        <ul class="area-hero__checks">
          <li><Icon name="check" size={18} /> Same-day in most of {area.name}</li>
          <li><Icon name="check" size={18} /> Licensed &amp; insured (Lic. #1126184)</li>
          <li><Icon name="check" size={18} /> Upfront pricing — no hourly creep</li>
        </ul>
      </div>
    </section>

    <!-- Area body — localized copy -->
    <section class="section">
      <div class="container area-body">
        <div class="area-body__col reveal">
          <span class="eyebrow">Local Service</span>
          <h2>What {area.name} homeowners call us for.</h2>
          <p>Every LA neighborhood has its own plumbing story — older clay sewer laterals, cast iron drains, slab construction, tight alley access. We've worked in {area.name} long enough to know what to expect before we arrive.</p>
          <ul class="area-body__list">
            <li><Icon name="check" size={18} /><span>Trenchless sewer repair &amp; replacement</span></li>
            <li><Icon name="check" size={18} /><span>Drain cleaning, hydro-jetting &amp; video inspection</span></li>
            <li><Icon name="check" size={18} /><span>Tank &amp; tankless water heater service</span></li>
            <li><Icon name="check" size={18} /><span>Copper &amp; PEX repipes</span></li>
            <li><Icon name="check" size={18} /><span>Gas line repair (C36 licensed)</span></li>
            <li><Icon name="check" size={18} /><span>Fixture &amp; appliance work</span></li>
          </ul>
        </div>
        <aside class="area-body__cta reveal">
          <span class="eyebrow">Emergency?</span>
          <h3>We answer 24/7 in {area.name}.</h3>
          <p>Burst pipe, backup, or gas smell — call and we'll dispatch a licensed tech right away.</p>
          <a class="btn btn--block btn--lg" href="tel:+13107800362">
            <Icon name="phone" size={20} /> (310) 780-0362
          </a>
        </aside>
      </div>
    </section>

    <ServicesGrid
      eyebrow={`In ${area.name}`}
      title={`The full scope of plumbing service in ${area.name}.`}
      lead="Filter by category or tap any card to see details. Every service is performed by our licensed crew."
    />

    <ContactSection
      eyebrow={`${area.name} Service Request`}
      title={`Book a job in ${area.name}.`}
      lead={`Tell us what's going on and we'll get back to you — often same day.`}
    />
  </main>

  <Footer />
  <StickyCall />
</BaseLayout>

<style>
  .area-hero {
    background:
      radial-gradient(ellipse at 90% 0%, rgba(63,194,238,0.2), transparent 55%),
      radial-gradient(ellipse at 10% 110%, rgba(229,32,42,0.2), transparent 55%),
      var(--ink);
    color: #fff;
    padding-block: clamp(3.5rem, 6vw, 5.5rem);
  }
  .area-hero__inner { max-width: 920px; }

  .area-hero__crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
  }
  .area-hero__crumbs a { color: var(--cyan); }

  .area-hero__title {
    color: #fff;
    margin: 1rem 0 1rem;
    max-width: 18ch;
  }

  .area-hero__lead {
    color: #c9ccd6;
    max-width: 60ch;
    font-size: 1.15rem;
    margin-bottom: 1.5rem;
  }

  .area-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 1.75rem;
  }

  .area-hero__checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
    color: #e5e7ec;
  }
  .area-hero__checks li { display: inline-flex; align-items: center; gap: 0.5rem; }
  .area-hero__checks :global(svg) { color: var(--cyan); }

  .area-body {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: start;
  }
  @media (max-width: 900px) { .area-body { grid-template-columns: 1fr; } }

  .area-body__list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
    display: grid;
    gap: 0.5rem;
  }
  .area-body__list li { display: flex; align-items: center; gap: 0.5rem; }
  .area-body__list :global(svg) { color: var(--red); }

  .area-body__cta {
    background: var(--ink);
    color: #fff;
    padding: 1.75rem;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    border-top: 4px solid var(--red);
  }
  .area-body__cta h3 { color: #fff; }
  .area-body__cta p { color: #c9ccd6; }
  .area-body__cta .eyebrow { color: var(--cyan); }
  .area-body__cta .eyebrow::before,
  .area-body__cta .eyebrow::after { background: var(--cyan); }
</style>
