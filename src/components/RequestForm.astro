---
import { services } from '../data/services';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

export interface Props {
  defaultService?: string;
  compact?: boolean;
  title?: string;
}

const { defaultService = '', compact = false, title = "Request Service" } = Astro.props;

const grouped: Record<string, typeof services> = {};
for (const s of services) {
  if (!grouped[s.category]) grouped[s.category] = [] as any;
  (grouped[s.category] as any).push(s);
}

const categoryLabels: Record<string, string> = {
  sewer: 'Sewer & Drain',
  water: 'Water & Heaters',
  pipe: 'Piping & Gas',
  fixture: 'Fixtures & Appliances',
};

const categoryOrder = ['sewer', 'water', 'pipe', 'fixture'];
---

<div class:list={['request-card', { 'request-card--compact': compact }]}>
  {!compact && (
    <div class="request-card__header">
      <span class="eyebrow">{title}</span>
      <h3>Tell us what you need.</h3>
      <p class="request-card__lead">We'll call you back with honest, upfront pricing.</p>
    </div>
  )}

  <form class="form" data-request-form novalidate autocomplete="on" spellcheck="false">
    {/* Web3Forms access key — get yours free at web3forms.com */}
    <input type="hidden" name="access_key" value={web3formsKey} />
    <input type="hidden" name="subject" value="New Service Request — Sewer Pipe Pros" />
    <div class="form__row">
      <div>
        <label for="rf-name">Full Name</label>
        <input
          id="rf-name"
          name="name"
          type="text"
          autocomplete="name"
          required
          minlength="2"
          maxlength="80"
          placeholder="Robert Manuel"
        />
      </div>
      <div>
        <label for="rf-phone">Phone</label>
        <input
          id="rf-phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          required
          maxlength="20"
          pattern="[\d\s()+\-.]{7,20}"
          placeholder="(310) 555-0000"
        />
      </div>
    </div>

    <div class="form__row">
      <div>
        <label for="rf-email">Email</label>
        <input
          id="rf-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          maxlength="120"
          placeholder="you@example.com"
        />
      </div>
      <div>
        <label for="rf-address">Address / ZIP</label>
        <input
          id="rf-address"
          name="address"
          type="text"
          autocomplete="street-address"
          required
          maxlength="160"
          placeholder="Street or ZIP"
        />
      </div>
    </div>

    <div>
      <label for="rf-service">Service Needed</label>
      <select id="rf-service" name="service" required>
        <option value="">Select a service…</option>
        {categoryOrder.map((cat) => (
          <optgroup label={categoryLabels[cat]}>
            {grouped[cat]?.map((s) => (
              <option value={s.slug} selected={s.slug === defaultService}>{s.title}</option>
            ))}
          </optgroup>
        ))}
        <option value="other">Not sure — please help me diagnose</option>
      </select>
    </div>

    <div>
      <label for="rf-message">Tell us what's going on</label>
      <textarea
        id="rf-message"
        name="message"
        rows="4"
        maxlength="1500"
        placeholder="Describe the issue, when it started, any signs like smell or backup…"
      ></textarea>
    </div>

    {/* Honeypot — hidden from humans, attractive to naive bots. Leave empty. */}
    <div class="form__honey" aria-hidden="true">
      <label for="rf-website">Website (leave blank)</label>
      <input id="rf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
    </div>

    {/* Cloudflare Turnstile widget — renders inline CAPTCHA challenge */}
    <div data-turnstile-widget class="form__captcha"></div>
    <input type="hidden" name="cf-turnstile-response" data-turnstile-token />

    <p class="form__error" data-error aria-live="polite"></p>

    <button type="submit" class="btn btn--block btn--lg" data-submit>
      Request Service Call →
    </button>

    <p class="form__hint">
      Or call us directly at <a href="tel:+13107800362">(310)&nbsp;780-0362</a>
    </p>
  </form>
</div>

<script>
  // REPLACE both placeholder keys below before going live:
  //   WEB3FORMS_KEY  → web3forms.com (free, no credit card)
  //   TURNSTILE_KEY  → dash.cloudflare.com → Turnstile (free)
  // Web3Forms verifies the Turnstile token server-side automatically.
  const TURNSTILE_SITE_KEY = `${import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? ''}`;

  // Load Turnstile script eagerly; render lazily on first form interaction.
  let tsReady = false;
  const pendingRenders: Array<() => void> = [];

  const tsScript = document.createElement('script');
  tsScript.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
  tsScript.async = true;
  document.head.appendChild(tsScript);
  tsScript.onload = () => {
    tsReady = true;
    pendingRenders.splice(0).forEach(fn => fn());
  };

  // Hard caps mirror the `maxlength` attrs on each input.
  const LIMITS = {
    name: 80,
    phone: 20,
    email: 120,
    address: 160,
    service: 80,
    message: 1500,
  } as const;

  // Strip anything that's almost never valid in a contact form field:
  //  • ASCII control chars (0x00–0x1F, 0x7F) other than tab/newline
  //  • zero-width + BOM / invisible tricks
  //  • angle brackets (cheap XSS tag hint)
  //  • collapse whitespace runs
  // Then trim + cap length.
  const sanitize = (raw: unknown, max: number, { multiline = false } = {}): string => {
    let s = String(raw ?? '');
    // Remove control chars (keep tab + newline only if multiline)
    s = multiline
      ? s.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '')
      : s.replace(/[\x00-\x1F\x7F]/g, '');
    // Strip zero-width + directional override characters used in spoofing
    s = s.replace(
      /[\u200B-\u200F\u2028-\u2029\u202A-\u202E\u2060\uFEFF]/g,
      ''
    );
    // Drop angle brackets entirely — no form field needs them
    s = s.replace(/[<>]/g, '');
    // Collapse whitespace runs
    s = multiline ? s.replace(/[ \t]{2,}/g, ' ') : s.replace(/\s{2,}/g, ' ');
    return s.trim().slice(0, max);
  };

  // Broad "looks like spam" sniff — URLs or markup in fields that should be a name.
  const looksSpammy = (s: string): boolean =>
    /(https?:\/\/|www\.|<\/?[a-z]|\[url=|javascript:|onerror=|onload=)/i.test(s);

  document.querySelectorAll<HTMLFormElement>('[data-request-form]').forEach((form) => {
    const errEl = form.querySelector<HTMLElement>('[data-error]');
    const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit]');
    const widget = form.querySelector<HTMLElement>('[data-turnstile-widget]');
    const tokenInput = form.querySelector<HTMLInputElement>('[data-turnstile-token]');

    let widgetRendered = false;

    const showAndRenderWidget = () => {
      if (widgetRendered || !widget) return;
      widgetRendered = true;
      widget.classList.add('is-visible');

      const doRender = () => {
        (window as any).turnstile?.render(widget, {
          sitekey: TURNSTILE_SITE_KEY,
          callback: (token: string) => {
            if (tokenInput) tokenInput.value = token;
          },
          'expired-callback': () => {
            if (tokenInput) tokenInput.value = '';
          },
          'error-callback': () => {
            if (tokenInput) tokenInput.value = '';
          },
        });
      };

      if (tsReady) { doRender(); } else { pendingRenders.push(doRender); }
    };

    form.addEventListener('input', () => showAndRenderWidget(), { once: true });
    form.addEventListener('focusin', () => showAndRenderWidget(), { once: true });

    // Time-gate: record when the form was rendered. Bots submit instantly.
    const renderedAt = Date.now();
    const MIN_FILL_MS = 1500;

    // Simple throttle so rapid-fire clicks don't retrigger.
    let lastSubmitAt = 0;
    const THROTTLE_MS = 8000;

    const showError = (msg: string, focusField?: string) => {
      if (!errEl) return;
      errEl.textContent = msg;
      if (focusField) {
        (form.elements.namedItem(focusField) as HTMLElement | null)?.focus();
      }
    };

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      if (!errEl || !submitBtn) return;
      errEl.textContent = '';

      // Throttle.
      const now = Date.now();
      if (now - lastSubmitAt < THROTTLE_MS) {
        showError('Please wait a moment before submitting again.');
        return;
      }

      // Honeypot: if a "website" value is set, it's a bot. Fail silently (reset + pretend success) so the bot moves on.
      const raw = new FormData(form);
      const honey = String(raw.get('website') || '').trim();
      if (honey) {
        form.reset();
        return;
      }

      // Turnstile: require a valid token before allowing submission.
      const turnstileToken = String(raw.get('cf-turnstile-response') || '').trim();
      if (!turnstileToken) {
        showError('Please complete the security check before submitting.');
        return;
      }

      // Time-gate.
      if (now - renderedAt < MIN_FILL_MS) {
        showError('Something went wrong. Please try again.');
        return;
      }

      // Sanitize every field.
      const name = sanitize(raw.get('name'), LIMITS.name);
      const phone = sanitize(raw.get('phone'), LIMITS.phone);
      const email = sanitize(raw.get('email'), LIMITS.email);
      const address = sanitize(raw.get('address'), LIMITS.address);
      const service = sanitize(raw.get('service'), LIMITS.service);
      const message = sanitize(raw.get('message'), LIMITS.message, { multiline: true });

      // Validate.
      if (!name || name.length < 2) {
        showError('Please enter your name.', 'name');
        return;
      }
      // Name should be mostly letters/spaces/hyphens/apostrophes (intl-safe).
      if (!/^[\p{L}][\p{L}\s'.\-]{1,79}$/u.test(name) || looksSpammy(name)) {
        showError('Please enter a valid name.', 'name');
        return;
      }

      // Phone: strip formatting, require ≥ 7 actual digits.
      const phoneDigits = phone.replace(/\D/g, '');
      if (phoneDigits.length < 7 || phoneDigits.length > 15 || !/^[\d\s()+\-.]+$/.test(phone)) {
        showError('Please enter a valid phone number.', 'phone');
        return;
      }

      // Email: simple robust pattern + no whitespace.
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) {
        showError('Please enter a valid email address.', 'email');
        return;
      }

      if (!address) {
        showError('Please enter your address or ZIP code.', 'address');
        return;
      }
      if (looksSpammy(address)) {
        showError('Please remove links from the address field.', 'address');
        return;
      }

      if (!service) {
        showError('Please choose a service.', 'service');
        return;
      }

      // Message is optional, but if present must not be spammy link-dump.
      if (message && (message.match(/https?:\/\//gi) || []).length > 2) {
        showError('Please reduce the number of links in your message.', 'message');
        return;
      }

      lastSubmitAt = now;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      const accessKey = (form.elements.namedItem('access_key') as HTMLInputElement)?.value ?? '';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            access_key: accessKey,
            name, phone, email, address, service, message,
          }),
        });
        const data = await res.json() as { success: boolean; message?: string };

        if (data.success) {
          errEl.textContent = '';
          form.reset();
          (window as any).turnstile?.reset();
          submitBtn.textContent = 'Request Sent!';
          setTimeout(() => {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Request Service Call →';
          }, 4000);
        } else {
          showError(data.message ?? 'Something went wrong. Please call us directly at (310) 780-0362.');
          (window as any).turnstile?.reset();
          submitBtn.disabled = false;
          submitBtn.textContent = 'Request Service Call →';
        }
      } catch {
        showError('Network error. Please call us directly at (310) 780-0362.');
        (window as any).turnstile?.reset();
        submitBtn.disabled = false;
        submitBtn.textContent = 'Request Service Call →';
      }
    });
  });
</script>

<style>
  .request-card {
    background: #fff;
    border-radius: var(--r-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-lg);
    border-top: 4px solid var(--red);
    position: relative;
  }
  .request-card::before {
    content: '';
    position: absolute;
    top: 4px;
    left: 1.75rem;
    right: 1.75rem;
    height: 4px;
    background: var(--cyan);
    border-radius: 2px;
  }

  .request-card--compact { padding: 1.25rem; }

  .request-card__header { margin-bottom: 1rem; }
  .request-card__header h3 {
    font-size: 1.7rem;
    margin-bottom: 0.25rem;
    color: var(--ink);
  }
  .request-card__lead {
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .form__captcha { margin-top: 0.25rem; display: none; }
  .form__captcha.is-visible { display: block; }

  /* Honeypot: invisible to humans, present in the DOM for bots to fill. */
  .form__honey {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
</style>
