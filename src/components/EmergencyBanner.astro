---
import Icon from './Icon.astro';
---

<section class="emergency">
  <span class="emergency__watermark" aria-hidden="true">24/7</span>

  <div class="container emergency__inner">
    <div class="emergency__copy reveal">
      <span class="chip chip--live"><span class="dot" aria-hidden="true"></span> Available Around the Clock</span>
      <h2 class="emergency__title">
        <span class="text-red">Plumbing emergency?</span><br />We answer the phone.
      </h2>
      <p class="emergency__sub">
        Burst pipe, sewer backup, gas leak, no hot water — we dispatch a licensed tech fast. No call trees, no third-party dispatcher, no surprise fees.
      </p>
      <ul class="emergency__checks">
        <li><Icon name="check" size={18} /> Dispatched by a real human</li>
        <li><Icon name="check" size={18} /> Upfront emergency pricing — no gouging</li>
        <li><Icon name="check" size={18} /> Licensed tech, fully insured</li>
      </ul>
    </div>

    <a href="tel:+13107800362" class="emergency__phone reveal">
      <span class="emergency__phone-label">Call Now</span>
      <span class="emergency__phone-num">(310)&nbsp;780&#8209;0362</span>
      <span class="emergency__phone-cta">
        <Icon name="phone" size={18} /> Tap to Dial
      </span>
    </a>
  </div>
</section>

<style>
  .emergency {
    position: relative;
    background:
      radial-gradient(ellipse at 80% 100%, rgba(229, 32, 42, 0.22), transparent 55%),
      radial-gradient(ellipse at 0% 0%, rgba(63, 194, 238, 0.12), transparent 55%),
      #15171f;
    color: #fff;
    padding-block: clamp(3.5rem, 6vw, 5.5rem);
    overflow: hidden;
    isolation: isolate;
  }

  .emergency__watermark {
    position: absolute;
    top: 50%;
    right: -2vw;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(14rem, 28vw, 26rem);
    line-height: 0.8;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 2px rgba(255,255,255,0.06);
    text-stroke: 2px rgba(255,255,255,0.06);
    z-index: -1;
    pointer-events: none;
    user-select: none;
  }

  .emergency__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .emergency__inner { grid-template-columns: 1fr; }
  }

  .emergency__title {
    color: #fff;
    font-size: clamp(2rem, 2.5vw + 1.1rem, 3.5rem);
    margin: 1rem 0 1.25rem;
  }

  .emergency__sub {
    font-size: 1.1rem;
    color: #c9ccd6;
    max-width: 56ch;
    margin-bottom: 1.5rem;
  }

  .emergency__checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .emergency__checks li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #e5e7ec;
  }
  .emergency__checks :global(svg) { color: var(--cyan); }

  .emergency__phone {
    display: grid;
    gap: 0.35rem;
    text-align: center;
    padding: 2rem 1.5rem;
    border: 3px solid var(--red);
    border-radius: var(--r-xl);
    background: rgba(229, 32, 42, 0.08);
    box-shadow: 0 18px 40px rgba(229,32,42,0.25), inset 0 0 40px rgba(229,32,42,0.08);
    color: #fff;
    position: relative;
    overflow: hidden;
    transition: transform var(--t-med), box-shadow var(--t-med), background var(--t-med);
  }
  .emergency__phone:hover {
    transform: translateY(-3px);
    box-shadow: 0 26px 60px rgba(229,32,42,0.35), inset 0 0 60px rgba(229,32,42,0.12);
    color: #fff;
    background: rgba(229, 32, 42, 0.15);
  }

  .emergency__phone-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .emergency__phone-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw + 1rem, 3.4rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .emergency__phone-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.9rem;
    color: #fff;
  }
</style>
