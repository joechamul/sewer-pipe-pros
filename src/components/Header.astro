---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/areas/', label: 'Service Areas' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  const normalized = href.replace(/\/$/, '');
  return pathname === normalized || pathname.startsWith(normalized + '/');
}
---

<header class="site-header" data-header>
  <div class="container-wide site-header__inner">
    <a href={`${base}/`} class="site-header__brand" aria-label="Sewer Pipe Pros home">
      <img
        src={`${base}/transparent-logo.png`}
        alt="Sewer Pipe Pros"
        class="site-header__logo"
        width="220"
        height="78"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {links.map((link) => (
          <li>
            <a
              href={`${base}${link.href === '/' ? '/' : link.href}`}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={['site-header__link', { 'is-active': isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__cta">
      <a href="tel:+13107800362" class="btn btn--sm-only">
        <Icon name="phone" size={18} /> (310) 780-0362
      </a>
    </div>

    <button class="site-header__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
      <Icon name="menu" size={26} class="icon-open" />
      <Icon name="close" size={26} class="icon-close" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Mobile">
      <ul>
        {links.map((link) => (
          <li>
            <a
              href={`${base}${link.href === '/' ? '/' : link.href}`}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={['mobile-menu__link', { 'is-active': isActive(link.href) }]}
            >
              {link.label}
              <Icon name="arrow-right" size={18} />
            </a>
          </li>
        ))}
      </ul>
      <a href="tel:+13107800362" class="btn btn--block">
        <Icon name="phone" size={18} /> Call (310) 780-0362
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const header = document.querySelector<HTMLElement>('[data-header]');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        menu.setAttribute('hidden', '');
        header?.classList.remove('is-menu-open');
        document.body.style.overflow = '';
      } else {
        menu.removeAttribute('hidden');
        header?.classList.add('is-menu-open');
        document.body.style.overflow = 'hidden';
      }
    });

    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('hidden', '');
        header?.classList.remove('is-menu-open');
        document.body.style.overflow = '';
      })
    );
  }

  // Add shadow after scroll
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 8) header.classList.add('is-scrolled');
    else header.classList.remove('is-scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid transparent;
    transition: box-shadow var(--t-fast), border-color var(--t-fast);
  }
  .site-header.is-scrolled {
    box-shadow: 0 6px 24px rgba(26,28,36,0.08);
    border-bottom-color: var(--line);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1.25rem;
    padding-block: 0.75rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    font-family: var(--font-display);
    line-height: 1;
  }
  .site-header__brand:hover { color: var(--ink); }

  .site-header__logo {
    height: 52px;
    width: auto;
    max-width: none;
    display: block;
    flex-shrink: 0;
  }

  .site-header__nav ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: center;
  }

  .site-header__link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 0.5rem 0.1rem;
    position: relative;
  }
  .site-header__link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 2px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-fast);
  }
  .site-header__link:hover,
  .site-header__link.is-active {
    color: var(--red);
  }
  .site-header__link:hover::after,
  .site-header__link.is-active::after {
    transform: scaleX(1);
  }

  .site-header__cta .btn { padding: 0.6rem 1rem; font-size: 0.95rem; }

  .site-header__toggle {
    display: none;
    width: 44px; height: 44px;
    align-items: center; justify-content: center;
    color: var(--ink);
  }
  .site-header__toggle :global(.icon-close) { display: none; }
  .site-header.is-menu-open .site-header__toggle :global(.icon-open) { display: none; }
  .site-header.is-menu-open .site-header__toggle :global(.icon-close) { display: block; }

  .mobile-menu {
    display: none;
    border-top: 1px solid var(--line);
    background: var(--paper);
    padding: 1rem 1.25rem 1.5rem;
  }
  .mobile-menu ul {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: grid;
    gap: 0.1rem;
  }
  .mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0.75rem;
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 8px;
  }
  .mobile-menu__link:hover,
  .mobile-menu__link.is-active {
    background: #fff;
    color: var(--red);
  }

  @media (max-width: 960px) {
    .site-header__nav { display: none; }
    .site-header__cta .btn {
      padding: 0.55rem 0.75rem;
      font-size: 0.85rem;
    }
    .site-header__toggle { display: inline-flex; }
    .site-header.is-menu-open .mobile-menu { display: block; }
  }

  @media (max-width: 560px) {
    .site-header__cta { display: none; }
    .site-header__inner { grid-template-columns: 1fr auto; gap: 0.75rem; }
    .site-header__logo { height: 42px; }
  }
</style>
