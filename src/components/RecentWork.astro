---
import Icon from './Icon.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Six photos chosen for the bento grid. Slot shapes are defined via CSS grid areas.
const jobs = [
  { slot: 'a', image: 'IMG_5930.jpg', title: 'Trenchless Main Line Replacement', meta: 'West LA · 2" → 4" ABS upgrade' },
  { slot: 'b', image: 'IMG_5923.jpg', title: 'Under-Slab Repipe',                 meta: 'Cut-out + ABS rough-in' },
  { slot: 'c', image: 'IMG_5920.jpg', title: 'Full Cleanout Install',             meta: 'Trenched · new ABS wye' },
  { slot: 'd', image: 'IMG_5927.jpg', title: 'Crawlspace Drain Repipe',           meta: 'Cast iron → ABS' },
  { slot: 'e', image: 'IMG_5926.jpg', title: 'Waste &amp; Vent Stack',                meta: 'Sub-floor access' },
  { slot: 'f', image: 'IMG_5921.jpg', title: 'Deep Excavation &amp; Tie-In',          meta: 'City main connection' },
];
---

<section class="work section" aria-labelledby="work-title">
  <div class="container">
    <header class="work__header">
      <div class="work__header-copy">
        <span class="eyebrow">Recent Work</span>
        <h2 id="work-title" class="section-title">Real jobs. Real photos. Greater LA.</h2>
        <p class="section-lead">
          Every home looks fine until you open it up. Here's what we've been fixing lately — unfiltered, with the job still in progress.
        </p>
      </div>
      <div class="work__header-stats" aria-hidden="true">
        <div class="work__stat">
          <span class="work__stat-num">300+</span>
          <span class="work__stat-label">Sewer lines<br/>serviced</span>
        </div>
        <div class="work__stat">
          <span class="work__stat-num">C36 · C42</span>
          <span class="work__stat-label">Dual license<br/>#1126184</span>
        </div>
      </div>
    </header>

    <div class="work__bento">
      {jobs.map((job) => (
        <figure class={`work__tile work__tile--${job.slot}`}>
          <img
            src={`${base}/jobs/${job.image}`}
            alt={`${job.title} — Sewer Pipe Pros Los Angeles`}
            loading="lazy"
            decoding="async"
          />
          <figcaption class="work__caption">
            <span class="work__caption-kicker">Field Proof</span>
            <strong>{job.title}</strong>
            <span class="work__caption-meta" set:html={job.meta}></span>
          </figcaption>
          <span class="work__tile-frame" aria-hidden="true"></span>
        </figure>
      ))}
    </div>

    <div class="work__footer">
      <div class="work__footer-text">
        <Icon name="shield" size={18} />
        <span>Every job photo is an actual Sewer Pipe Pros installation — not a stock image.</span>
      </div>
      <a class="btn btn--cyan" href="#request-form">
        Request a Quote <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </div>
</section>

<style>
  .work {
    position: relative;
    background: var(--paper);
  }

  .work__header {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2rem;
    align-items: end;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 820px) {
    .work__header { grid-template-columns: 1fr; }
  }
  .work__header-copy .section-lead { margin-bottom: 0; }

  .work__header-stats {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }
  @media (max-width: 820px) { .work__header-stats { justify-content: flex-start; } }

  .work__stat {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1rem 1.25rem;
    display: grid;
    gap: 0.15rem;
    min-width: 140px;
    box-shadow: var(--shadow-sm);
    border-top: 3px solid var(--red);
  }
  .work__stat:nth-child(2) { border-top-color: var(--cyan); }
  .work__stat-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.75rem;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .work__stat-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.3;
  }

  /* ─── Bento grid ─── */
  .work__bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(4, 120px);
    gap: 0.75rem;
    grid-template-areas:
      "a a b b c c"
      "a a b b c c"
      "d d e f f f"
      "d d e f f f";
  }

  .work__tile--a { grid-area: a; }
  .work__tile--b { grid-area: b; }
  .work__tile--c { grid-area: c; }
  .work__tile--d { grid-area: d; }
  .work__tile--e { grid-area: e; }
  .work__tile--f { grid-area: f; }

  .work__tile {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-card);
    background: #0d0e14;
    cursor: default;
    isolation: isolate;
  }
  .work__tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease), filter 0.5s var(--ease);
    filter: saturate(1.04) contrast(1.06) brightness(0.96);
  }
  .work__tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(0,0,0,0.78) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .work__tile:hover img {
    transform: scale(1.06);
    filter: saturate(1.1) contrast(1.08) brightness(1);
  }

  .work__tile-frame {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(255,255,255,0.1);
    pointer-events: none;
    z-index: 2;
    transition: border-color var(--t-med), box-shadow var(--t-med);
  }
  .work__tile:hover .work__tile-frame {
    border-color: rgba(63, 194, 238, 0.65);
    box-shadow: inset 0 0 0 1px rgba(63, 194, 238, 0.35);
  }

  .work__caption {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.9rem;
    z-index: 3;
    display: grid;
    gap: 0.1rem;
    color: #fff;
    line-height: 1.25;
  }
  .work__caption-kicker {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .work__caption strong {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(0.95rem, 0.5vw + 0.75rem, 1.15rem);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .work__caption-meta {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
  }

  @media (max-width: 820px) {
    .work__bento {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(6, 110px);
      grid-template-areas:
        "a a b b"
        "a a b b"
        "c c d d"
        "c c d d"
        "e f f f"
        "e f f f";
    }
  }
  @media (max-width: 540px) {
    .work__bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(6, 150px);
      grid-template-areas:
        "a a"
        "b c"
        "d d"
        "e f"
        "e f"
        "f f";
    }
    /* Simplify: just a 2-col tall grid */
    .work__bento {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 180px;
      grid-template-rows: none;
      grid-template-areas: none;
    }
    .work__tile { grid-area: auto !important; }
    .work__tile--a, .work__tile--f { grid-column: span 2; }
  }

  /* ─── Footer ─── */
  .work__footer {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px dashed var(--line);
    border-radius: var(--radius-card);
  }
  .work__footer-text {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .work__footer-text :global(svg) { color: var(--red); flex-shrink: 0; }
</style>
