---
import Icon from './Icon.astro';

export interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="about section">
  <div class="container about__grid">
    <!-- Left: visual card -->
    <div class="about__visual reveal">
      <div class="about__visual-card">
        <img
          src={`${base}/logo-black.png`}
          alt="Sewer Pipe Pros logo"
          class="about__logo"
          width="666"
          height="306"
          loading="lazy"
          decoding="async"
        />

        <div class="about__badge">
          <span class="about__badge-kicker">Licensed</span>
          <span class="about__badge-num">#1126184</span>
          <span class="about__badge-class">C36 · C42</span>
        </div>
      </div>
    </div>

    <!-- Right: copy -->
    <div class="about__copy reveal">
      <span class="eyebrow">Who We Are</span>
      <h2>Honest, licensed plumbing — built on a different kind of service.</h2>
      <p>
        Sewer Pipe Pros Inc. was built by Robert Manuel Chamul on a simple idea: plumbing work should be upfront, explained, and done right the first time. Too many LA homeowners have been burned by vague pricing, pushy upsells, and techs who disappear the moment a warranty claim comes in.
      </p>
      <p>
        We run things differently. Every job starts with a real diagnosis. Every price is explained before we pick up a wrench. Every service — from a toilet reset to a full trenchless sewer replacement — is performed by a licensed team that treats your home like their own.
      </p>
      <p>
        We're a Greater Los Angeles contractor holding both a <strong>C36 plumbing license</strong> and a <strong>C42 sanitation systems license</strong> — which means we can legally (and competently) handle everything from your kitchen sink to your main sewer line.
      </p>

      {!compact && (
        <div class="about__signature">
          <div class="about__signature-avatar" aria-hidden="true">RMC</div>
          <div class="about__signature-text">
            <strong>Robert Manuel Chamul</strong>
            <span>Owner · Sewer Pipe Pros Inc.</span>
          </div>
          <div class="about__signature-divider" aria-hidden="true"></div>
          <div class="about__signature-slogan">
            <Icon name="shield" size={16} />
            <span>We Serve Differently</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  @media (max-width: 900px) {
    .about__grid { grid-template-columns: 1fr; }
  }

  .about__visual-card {
    position: relative;
    background: #000;
    border: 1px solid #000;
    border-radius: var(--r-xl);
    padding: clamp(2rem, 4vw, 3.25rem);
    max-width: 560px;
    margin-inline: auto;
    box-shadow: var(--shadow-lg);
    display: grid;
    place-items: center;
    min-height: 320px;
  }

  .about__logo {
    width: 100%;
    max-width: 460px;
    height: auto;
    display: block;
  }

  .about__badge {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    background: #fff;
    color: var(--ink);
    padding: 0.8rem 1rem;
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    display: grid;
    border-top: 3px solid var(--red);
  }
  .about__badge-kicker {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    color: var(--red);
    text-transform: uppercase;
    font-weight: 800;
  }
  .about__badge-num {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 900;
    line-height: 1;
  }
  .about__badge-class {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .about__copy h2 { max-width: 22ch; }

  .about__signature {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }
  .about__signature-avatar {
    width: 54px;
    height: 54px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.06em;
    font-size: 1rem;
    box-shadow: 0 6px 20px rgba(229,32,42,0.3);
    flex-shrink: 0;
  }
  .about__signature-text { display: grid; line-height: 1.2; }
  .about__signature-text strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    text-transform: uppercase;
  }
  .about__signature-text span { color: var(--muted); font-size: 0.9rem; }

  .about__signature-divider {
    width: 1px;
    height: 36px;
    background: var(--line);
  }
  @media (max-width: 520px) {
    .about__signature-divider { display: none; }
  }

  .about__signature-slogan {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--red);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.9rem;
  }
</style>
