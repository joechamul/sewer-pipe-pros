---
import Icon from './Icon.astro';

export interface Props {
  slug: string;
  title: string;
  category: string;
  icon: string;
  shortDescription: string;
}

const { slug, title, category, icon, shortDescription } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="service-card reveal" data-category={category}>
  <a class="service-card__link" href={`${base}/services/${slug}/`}>
    <div class="service-card__icon" aria-hidden="true">
      <Icon name={icon} size={28} />
    </div>
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__desc">{shortDescription}</p>
    <span class="service-card__cta">
      Learn More
      <Icon name="arrow-right" size={16} />
    </span>
  </a>
</article>

<style>
  .service-card {
    position: relative;
    background: #fff;
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    overflow: hidden;
    transition: transform var(--t-med), box-shadow var(--t-med);
  }

  /* Left red border accent */
  .service-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--red);
    transform: scaleY(0.2);
    transform-origin: center;
    transition: transform var(--t-med);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(26,28,36,0.18);
  }
  .service-card:hover::before { transform: scaleY(1); }

  .service-card__link {
    display: grid;
    gap: 0.75rem;
    padding: 1.5rem 1.4rem 1.25rem;
    color: var(--ink);
    height: 100%;
  }
  .service-card__link:hover { color: var(--ink); }

  .service-card__icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: linear-gradient(135deg, #f6f4ef, #ffffff);
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
    color: var(--ink);
    transition: background var(--t-med), color var(--t-med), border-color var(--t-med), transform var(--t-med);
  }
  .service-card:hover .service-card__icon {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: #fff;
    border-color: var(--red-dark);
    transform: rotate(-4deg);
  }

  .service-card__title {
    font-size: 1.15rem;
    margin: 0;
    line-height: 1.15;
  }

  .service-card__desc {
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.55;
  }

  .service-card__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--red);
  }
  .service-card:hover .service-card__cta :global(svg) {
    transform: translateX(3px);
  }
  .service-card__cta :global(svg) { transition: transform var(--t-med); }

  /* .is-hidden is applied by the category filter in ServicesGrid.astro.
     Declared as :global so JS-toggled class reliably hides the article
     regardless of Astro's style scoping. */
  :global(.service-card.is-hidden) {
    display: none !important;
  }
</style>
