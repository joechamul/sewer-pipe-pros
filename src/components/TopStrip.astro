---
import Icon from './Icon.astro';
---

<div class="top-strip" role="region" aria-label="Business hours and contact">
  <div class="container-wide top-strip__inner">
    <div class="top-strip__left">
      <span class="chip chip--live"><span class="dot" aria-hidden="true"></span> 24/7 Emergency Service</span>
      <span class="top-strip__item top-strip__item--hide-sm">
        <Icon name="map-pin" size={14} /> Greater Los Angeles
      </span>
      <span class="top-strip__item top-strip__item--hide-sm">
        <Icon name="shield" size={14} /> Lic. #1126184 · C36 &amp; C42
      </span>
    </div>
    <div class="top-strip__right">
      <a href="tel:+13107800362" class="top-strip__call">
        <Icon name="phone" size={14} /> (310) 780-0362
      </a>
    </div>
  </div>
</div>

<style>
  .top-strip {
    background: var(--ink);
    color: #fff;
    font-size: 0.82rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .top-strip__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.55rem;
    flex-wrap: wrap;
  }
  .top-strip__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .top-strip__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.02em;
  }
  .top-strip__item :global(svg) { color: var(--cyan); }
  .top-strip__call {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #fff;
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    font-size: 0.95rem;
  }
  .top-strip__call:hover { color: var(--cyan); }
  .top-strip__call :global(svg) { color: var(--red); }

  @media (max-width: 640px) {
    .top-strip__item--hide-sm { display: none; }
  }
</style>
