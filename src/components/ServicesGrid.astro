---
import ServiceCard from './ServiceCard.astro';
import { services, categories } from '../data/services';

export interface Props {
  title?: string;
  eyebrow?: string;
  lead?: string;
  showFilters?: boolean;
  initialRows?: number;
}

const {
  title = 'Full-service plumbing, done right.',
  eyebrow = 'What We Do',
  lead = '23 services across sewer, water, piping, gas, and fixtures — all performed by licensed techs with upfront pricing.',
  showFilters = true,
  initialRows = 3,
} = Astro.props;
---

<section class="services section" id="services">
  <div class="container">
    <header class="services__header">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-lead">{lead}</p>

      {showFilters && (
        <div class="services__filters" role="tablist" aria-label="Service categories">
          <button
            type="button"
            class="services__chip is-active"
            role="tab"
            aria-selected="true"
            data-filter="all"
          >
            All
          </button>
          {categories.map((cat) => (
            <button
              type="button"
              class="services__chip"
              role="tab"
              aria-selected="false"
              data-filter={cat.id}
            >
              {cat.label}
            </button>
          ))}
        </div>
      )}
    </header>

    <div
      class="services__grid"
      data-services-grid
      data-initial-rows={initialRows}
      data-collapsed="true"
    >
      {services.map((s) => (
        <ServiceCard
          slug={s.slug}
          title={s.title}
          category={s.category}
          icon={s.icon}
          shortDescription={s.shortDescription}
        />
      ))}
    </div>

    <div class="services__more-row" data-more-row hidden>
      <button type="button" class="services__show-more" data-show-more aria-expanded="false">
        <span data-show-more-label>Show More</span>
        <svg
          class="services__show-more-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  // ServicesGrid interactions:
  //   1. Category filter (chips) — hide cards that don't match.
  //   2. 3-row collapse — show only the first N rows of currently-visible cards,
  //      with a "Show more" button in the bottom right. On filter change, re-collapse.
  //      The row count depends on grid columns, which change with viewport width,
  //      so we re-evaluate on resize.

  const initServicesGrid = () => {
    const grid = document.querySelector<HTMLElement>('[data-services-grid]');
    if (!grid) return;

    const chips = document.querySelectorAll<HTMLButtonElement>('.services__chip');
    const cards = Array.from(
      grid.querySelectorAll<HTMLElement>('[data-category]')
    );
    const moreRow = document.querySelector<HTMLElement>('[data-more-row]');
    const moreBtn = document.querySelector<HTMLButtonElement>('[data-show-more]');
    const moreLabel = document.querySelector<HTMLElement>('[data-show-more-label]');

    const initialRows = Number(grid.dataset.initialRows || '3');

    const getColumnCount = (): number => {
      const computed = getComputedStyle(grid);
      const template = computed.gridTemplateColumns || '';
      const count = template.split(' ').filter(Boolean).length;
      return Math.max(1, count);
    };

    // Hard threshold: the Show More button only appears when there are more
    // than MIN_FOR_BUTTON visible cards. Below that, we show everything inline.
    const MIN_FOR_BUTTON = 12;

    const applyCollapse = () => {
      const collapsed = grid.dataset.collapsed !== 'false';
      const visible = cards.filter((c) => !c.classList.contains('is-hidden'));
      const cols = getColumnCount();
      const limit = cols * initialRows;
      const showButton = visible.length > MIN_FOR_BUTTON;

      cards.forEach((c) => c.classList.remove('is-collapsed'));

      if (collapsed && showButton) {
        visible.slice(limit).forEach((c) => c.classList.add('is-collapsed'));
      }

      if (moreRow && moreBtn && moreLabel) {
        if (showButton) {
          moreRow.hidden = false;
          moreBtn.setAttribute('aria-expanded', String(!collapsed));
          moreLabel.textContent = collapsed ? 'Show More' : 'Show Less';
          moreBtn.classList.toggle('is-expanded', !collapsed);
        } else {
          moreRow.hidden = true;
        }
      }
    };

    // ---- Filter chips ----
    chips.forEach((chip) => {
      chip.addEventListener('click', (ev) => {
        ev.preventDefault();
        const filter = chip.dataset.filter || 'all';

        chips.forEach((c) => {
          const active = c === chip;
          c.classList.toggle('is-active', active);
          c.setAttribute('aria-selected', String(active));
        });

        cards.forEach((card) => {
          const cat = card.getAttribute('data-category') || '';
          const show = filter === 'all' || cat === filter;
          card.classList.toggle('is-hidden', !show);
        });

        // Re-collapse to first N rows whenever the filter changes.
        grid.dataset.collapsed = 'true';
        applyCollapse();
      });
    });

    // ---- Show more / Show less ----
    if (moreBtn) {
      moreBtn.addEventListener('click', () => {
        const collapsed = grid.dataset.collapsed !== 'false';
        grid.dataset.collapsed = collapsed ? 'false' : 'true';
        applyCollapse();

        // When collapsing back, scroll the grid into view so it doesn't feel jumpy.
        if (!collapsed) {
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }

    // ---- Re-apply on resize (column count may change) ----
    let resizeTimer: number | undefined;
    window.addEventListener(
      'resize',
      () => {
        if (resizeTimer) window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(applyCollapse, 120);
      },
      { passive: true }
    );

    // Initial pass.
    applyCollapse();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServicesGrid);
  } else {
    initServicesGrid();
  }
</script>

<style>
  .services__header { margin-bottom: 2.5rem; }

  .services__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .services__chip {
    padding: 0.55rem 1.1rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: #fff;
    border: 1.5px solid var(--line);
    border-radius: 999px;
    transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  }
  .services__chip:hover {
    border-color: var(--ink);
  }
  .services__chip.is-active {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.15rem;
  }

  .services__more-row {
    display: flex;
    justify-content: flex-end;
    margin-top: 1.5rem;
  }
  /* [hidden] would normally be overridden by display:flex — force it off. */
  .services__more-row[hidden] {
    display: none !important;
  }

  .services__show-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    background: #fff;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    box-shadow: 0 4px 0 var(--ink);
    transition:
      transform var(--t-fast),
      box-shadow var(--t-fast),
      background var(--t-fast),
      color var(--t-fast);
  }
  .services__show-more:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 var(--ink);
    background: var(--ink);
    color: #fff;
  }
  .services__show-more:active {
    transform: translateY(1px);
    box-shadow: 0 2px 0 var(--ink);
  }

  .services__show-more-icon {
    transition: transform var(--t-med);
    /* Chevron points down by default (Show More) */
  }
  .services__show-more.is-expanded .services__show-more-icon {
    transform: rotate(180deg); /* Show Less: flip to point up */
  }

  /* Collapse rule is global so JS-toggled class wins over Astro scoping. */
  :global(.service-card.is-collapsed) {
    display: none !important;
  }
</style>
